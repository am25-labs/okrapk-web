---
import Card from "@/components/ui/astro/Card.astro";
import type { LogoTileProps } from "@/types";

type Props = LogoTileProps;

const { logo, title, href } = Astro.props;
const Tag = href ? "a" : "div";
const isExternal = href?.startsWith("https");
---

<Tag
  href={href}
  target={isExternal ? "_blank" : undefined}
  rel={isExternal ? "noopener" : undefined}
  {title}
  class="group"
>
  <Card class="flex justify-center aspect-square">
    <div slot="content">
      <img src={logo} alt={title} class="w-full p-4" />
    </div>
  </Card>
  <p class="text-muted-foreground text-xs mt-2 group-hover:underline">
    {title}
  </p>
</Tag>
