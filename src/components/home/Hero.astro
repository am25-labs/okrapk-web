---
import GridContainer from "@/layouts/GridContainer.astro";
import GridFour from "@/layouts/grids/GridFour.astro";
import Button from "@/components/ui/astro/Button.astro";

const DOWNLOAD_WINDOWS =
  "https://github.com/am25-labs/okrapk/releases/download/0.3.0/OKRA_0.3.0_x64-setup.exe";
const DOWNLOAD_MACOS =
  "https://github.com/am25-labs/okrapk/releases/download/0.3.0/OKRA_0.3.0_universal.dmg";
---

<GridContainer class="pb-24 items-center">
  <GridFour class="pb-16 md:pb-0">
    <div class="col-span-full md:pr-4">
      <div class="flex flex-col">
        <h2 class="text-3xl leading-normal mb-8">
          Pick any color on your screen with a global hotkey
        </h2>
        <a
          id="btn-windows"
          href={DOWNLOAD_WINDOWS}
          target="_blank"
          rel="noopener"
          class="w-fit hidden"
        >
          <Button size="lg">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 640 640"
              fill="currentColor"
            >
              <path
                d="M96 157.7L279.6 132.4L279.6 309.8L96 309.8L96 157.7zM96 482.3L279.6 507.6L279.6 332.4L96 332.4L96 482.3zM299.8 510.3L544 544L544 332.4L299.8 332.4L299.8 510.3zM299.8 129.7L299.8 309.8L544 309.8L544 96L299.8 129.7z"
              ></path>
            </svg>
            Install for Windows
          </Button>
        </a>
        <a
          id="btn-macos"
          href={DOWNLOAD_MACOS}
          target="_blank"
          rel="noopener"
          class="w-fit hidden"
        >
          <Button size="lg">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 640 640"
              fill="currentColor"
            >
              <path
                d="M447.1 332.7C446.9 296 463.5 268.3 497.1 247.9C478.3 221 449.9 206.2 412.4 203.3C376.9 200.5 338.1 224 323.9 224C308.9 224 274.5 204.3 247.5 204.3C191.7 205.2 132.4 248.8 132.4 337.5C132.4 363.7 137.2 390.8 146.8 418.7C159.6 455.4 205.8 545.4 254 543.9C279.2 543.3 297 526 329.8 526C361.6 526 378.1 543.9 406.2 543.9C454.8 543.2 496.6 461.4 508.8 424.6C443.6 393.9 447.1 334.6 447.1 332.7zM390.5 168.5C417.8 136.1 415.3 106.6 414.5 96C390.4 97.4 362.5 112.4 346.6 130.9C329.1 150.7 318.8 175.2 321 202.8C347.1 204.8 370.9 191.4 390.5 168.5z"
              ></path>
            </svg>
            Install for macOS
          </Button>
        </a>
        <p class="text-xs mt-2">* Beta release</p>
      </div>
    </div>
  </GridFour>

  <GridFour>
    <div class="col-span-full">
      <img
        id="hero-windows"
        src="/hero-windows.png"
        alt="Hero Image"
        class="w-full h-auto hidden"
      />
      <img
        id="hero-macos"
        src="/hero-macos.png"
        alt="Hero Image"
        class="w-full h-auto hidden"
      />
    </div>
  </GridFour>
</GridContainer>

<script>
  const ua = navigator.userAgent;
  const isMac = /Macintosh|MacIntel|MacPPC|Mac68K/.test(ua);

  const suffix = isMac ? "macos" : "windows";
  document.getElementById(`btn-${suffix}`)?.classList.remove("hidden");
  document.getElementById(`hero-${suffix}`)?.classList.remove("hidden");
</script>
