---
import "../styles/globals.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import type { RootLayoutProps } from "@/types";

type Props = RootLayoutProps;

const { title = "AM25 | Design & Web Studio" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
    <script
      is:inline
      defer
      data-domain="am25.work"
      src="https://analytics.alemartir.com/js/script.outbound-links.tagged-events.js"
    ></script>
  </head>

  <body class="bg-black text-white font-martian min-h-dvh flex flex-col">
    <Header />

    <main class="max-w-7xl mx-auto w-full flex-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>
